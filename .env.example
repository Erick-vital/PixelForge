# Copy to .env for local runs. Tests disable .env with APP_ENV_FILE="".
APP_LOG_LEVEL=INFO
APP_DATA_DIR=data
APP_ITEMS_DIR=items

# Optional LLM configuration
APP_LLM_PROVIDER=openai_compatible
APP_LLM_MODEL=gpt-4o-mini
APP_LLM_BASE_URL=https://api.openai.com/v1
APP_LLM_API_KEY=
APP_OPENAI_API_KEY=
APP_ANTHROPIC_API_KEY=
